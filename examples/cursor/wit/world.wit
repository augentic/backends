// Guest world for the cursor example's `ask` guest: import the
// `omnia:model/completion` boundary and call `complete`. The guest's trigger is
// its `wasi:http` export (generated by `wasip3`), so this world declares only
// the import.
package augentic:cursor-example@0.1.0;

world caller {
    import omnia:model/completion@0.1.0;
}
